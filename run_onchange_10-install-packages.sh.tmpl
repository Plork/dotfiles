#!/bin/bash
# Install all packages from Brewfile.
# Re-runs automatically when Brewfile changes.
# Re-run manually with: brew bundle install --file=~/dotfiles/macos/Brewfile
# Brewfile hash: {{ include "macos/Brewfile" | sha256sum }}

set -euo pipefail

eval "$(/opt/homebrew/bin/brew shellenv)"
brew bundle install --file="${CHEZMOI_SOURCE_DIR}/macos/Brewfile"
