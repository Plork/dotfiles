#!/usr/bin/env bash
# Syncs ~/.kube/config to 1Password when the file changes.
# Triggered by launchd WatchPaths on ~/.kube/config.

set -euo pipefail

eval "$(/opt/homebrew/bin/brew shellenv)"

ITEM_UUID="wlhl4toh2lgbpvbs44tdllwkda"
ACCOUNT="{{ .onePasswordAccount }}"
KUBECONFIG="${HOME}/.kube/config"
LOG="${HOME}/Library/Logs/sync-kubeconfig.log"

notify() {
  osascript -e "display notification \"$1\" with title \"1Password Sync\"" 2>/dev/null || true
}

ensure_op_signed_in() {
  if op account get --account "${ACCOUNT}" &>/dev/null; then
    return 0
  fi

  echo "$(date): not signed in to 1Password, attempting sign-in..." >> "${LOG}"

  if [ -t 0 ]; then
    # Running in a terminal — interactive sign-in
    eval "$(op signin --account "${ACCOUNT}")" 2>>"${LOG}"
  else
    # No terminal (launchd) — notify the user and attempt sign-in via the 1Password app
    notify "Please unlock 1Password. Kubeconfig sync will retry on next change."
    eval "$(op signin --account "${ACCOUNT}" 2>>"${LOG}")" 2>/dev/null || true
  fi

  if ! op account get --account "${ACCOUNT}" &>/dev/null; then
    echo "$(date): sign-in failed, will retry on next change" >> "${LOG}"
    return 1
  fi

  echo "$(date): signed in to 1Password successfully" >> "${LOG}"
}

if [ ! -f "${KUBECONFIG}" ]; then
  echo "$(date): kubeconfig not found, skipping" >> "${LOG}"
  exit 0
fi

if ! ensure_op_signed_in; then
  exit 1
fi

op document edit "${ITEM_UUID}" "${KUBECONFIG}" --account "${ACCOUNT}" >> "${LOG}" 2>&1
echo "$(date): kubeconfig synced to 1Password" >> "${LOG}"
