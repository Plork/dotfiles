#!/usr/bin/env bash
# Syncs ~/.aws/config to 1Password when the file changes.
# Triggered by launchd WatchPaths on ~/.aws/config.

set -euo pipefail

eval "$(/opt/homebrew/bin/brew shellenv)"

ITEM_UUID="n6zozpextfve6e3v2cz3vw72k4"
ACCOUNT="{{ .onePasswordAccount }}"
AWS_CONFIG="${HOME}/.aws/config"
LOG="${HOME}/Library/Logs/sync-aws-config.log"

if [ ! -f "${AWS_CONFIG}" ]; then
  echo "$(date): aws config not found, skipping" >> "${LOG}"
  exit 0
fi

if ! op account get --account "${ACCOUNT}" &>/dev/null; then
  echo "$(date): not signed in to 1Password, skipping" >> "${LOG}"
  exit 0
fi

op document edit "${ITEM_UUID}" "${AWS_CONFIG}" --account "${ACCOUNT}" >> "${LOG}" 2>&1
echo "$(date): aws config synced to 1Password" >> "${LOG}"
